{
  "name": "itlabbd-next-cms",
  "version": "18.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "typecheck": "prisma generate && tsc --noEmit",
    "lint": "tsx scripts/lint-project.ts && tsc --noEmit --incremental false",
    "db:generate": "prisma generate",
    "db:migrate": "tsx scripts/ensure-env.ts && prisma migrate dev",
    "db:deploy": "tsx scripts/ensure-env.ts && prisma migrate deploy",
    "db:seed": "tsx scripts/ensure-env.ts && tsx prisma/seed.ts",
    "backend:check": "tsx scripts/ensure-env.ts && tsx scripts/check-backend.ts",
    "postinstall": "prisma generate",
    "db:repair": "powershell -ExecutionPolicy Bypass -File ./scripts/repair-db.ps1",
    "db:repair:unix": "sh ./scripts/repair-db.sh",
    "setup:local": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-local.ps1",
    "admin:hash": "tsx scripts/generate-admin-hash.ts",
    "backup:create": "tsx scripts/backup-db.ts MANUAL",
    "backup:daily": "tsx scripts/backup-db.ts DAILY",
    "backup:weekly": "tsx scripts/backup-db.ts WEEKLY",
    "backup:monthly": "tsx scripts/backup-db.ts MONTHLY",
    "preflight": "npm run lint && npm run typecheck && npm audit --audit-level=high && npm run build",
    "ci:check": "npm run lint && npm run typecheck && npm audit --audit-level=high && npm run build",
    "prod:check": "tsx scripts/check-production-env.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@prisma/client": "^6.19.0",
    "@vercel/analytics": "1.6.1",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "framer-motion": "^12.23.24",
    "jose": "^6.1.0",
    "lucide-react": "^0.468.0",
    "next": "^16.2.9",
    "nodemailer": "^8.0.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "redis": "^5.9.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.12",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/nodemailer": "^7.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
