# Docker PostgreSQL bootstrap. Generate unique random values before first startup.
POSTGRES_DB="itlabbd"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="replace-with-a-random-postgres-superuser-password"
APP_DB_PASSWORD="replace-with-a-different-random-application-password"
DATABASE_URL="postgresql://itlabbd:replace-with-the-same-application-password@postgres:5432/itlabbd?schema=public"

# Admin bootstrap credentials
ADMIN_USERNAME="admin"
ADMIN_EMAIL="info@example.com"
# Local-only convenience. Remove this plain password on production after seeding.
ADMIN_PASSWORD="ChangeThisBeforeUse"
# Production: npm run admin:hash -- "YourStrongPassword"
ADMIN_PASSWORD_HASH='$2b$12$replace-this-with-a-real-bcrypt-hash'
SESSION_SECRET="replace-with-at-least-48-random-characters"
ALLOW_ENV_AUTH_FALLBACK="false"
ADMIN_FORCE_PASSWORD_SYNC="false"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
SITE_URL="http://localhost:3000"
# Production value must be: https://itlabbd.com

ANALYTICS_HASH_SECRET="replace-with-a-long-random-analytics-secret"
REDIS_URL="redis://127.0.0.1:6379"
REDIS_CONNECT_TIMEOUT_MS="700"
REDIS_OPERATION_TIMEOUT_MS="700"
CMS_QUERY_TIMEOUT_MS="4000"
CMS_SEO_QUERY_TIMEOUT_MS="1200"
CMS_CACHE_DISABLED="false"
CMS_CACHE_TTL_SECONDS="60"
CMS_FALLBACK_CACHE_TTL_SECONDS="15"
CMS_DEBUG_TIMING="false"

SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="IT Lab BD <no-reply@example.com>"
ADMIN_NOTIFICATION_EMAIL="info@example.com"

# Persistent VPS directories outside the release folder.
UPLOAD_DIR="./storage/uploads"
DOWNLOAD_DIR="./storage/downloads"
BACKUP_DIR="./storage/backups"
PG_DUMP_PATH="pg_dump"
PG_RESTORE_PATH="pg_restore"
ALLOW_ADMIN_RESTORE="false"
# Enable only when Next.js is reachable solely through the included Nginx reverse proxy.
TRUST_PROXY_HEADERS="false"
# Keep true on production: reject sensitive writes if Redis is unavailable.
RATE_LIMIT_FAIL_CLOSED="true"
ADMIN_UPLOAD_LIMIT_PER_HOUR="250"
ADMIN_DOWNLOAD_UPLOAD_LIMIT_PER_HOUR="120"
MAX_IMAGE_UPLOAD_BYTES="10485760"
MAX_IMAGE_INPUT_PIXELS="36000000"
MAX_DOWNLOAD_UPLOAD_BYTES="52428800"
