generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  CLOSED
  SPAM
}

enum BackupType {
  MANUAL
  DAILY
  WEEKLY
  MONTHLY
}

enum BackupStatus {
  READY
  FAILED
}

enum SectionType {
  HERO
  ABOUT
  COUNTERS
  SERVICES
  PLATFORMS
  WHAT_WE_DO
  PORTFOLIO
  TESTIMONIALS
  TRUSTED_COMPANIES
  CONTACT
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String?  
  email        String?
  active       Boolean  @default(true)
  sessionVersion      Int       @default(0)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  resetTokens    PasswordResetToken[]
  activityLogs   ActivityLog[]
  databaseBackups DatabaseBackup[]
}



model TeamMember {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  role       String
  bio        String?
  imageUrl   String
  skills     Json?
  experience String?
  email      String?
  published  Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([published, sortOrder])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model Settings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  group       String   @default("general")
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([group, key])
}

model Menu {
  id        String   @id @default(cuid())
  label     String
  href      String
  parentId  String?
  sortOrder Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, sortOrder])
  @@index([parentId])
}

model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?
  content     Json
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, title])
}

model HomepageSection {
  id        String      @id @default(cuid())
  type      SectionType @unique
  title     String
  enabled   Boolean     @default(true)
  sortOrder Int         @default(0)
  content   Json
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([enabled, sortOrder])
}

model Service {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     Json?
  icon        String?
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, sortOrder])
}

model PortfolioCategory {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  projects  Portfolio[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Portfolio {
  id           String            @id @default(cuid())
  slug         String            @unique
  title        String
  excerpt      String?
  imageUrl     String
  screenshots  Json?
  technologies Json?
  liveUrl      String?
  buttonLabel  String?
  buttonUrl    String?
  caseStudy    Json?
  published    Boolean           @default(true)
  sortOrder    Int               @default(0)
  categoryId   String?
  category     PortfolioCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([published, sortOrder])
  @@index([categoryId])
}

model DemoCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  demos     Demo[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Demo {
  id         String        @id @default(cuid())
  slug       String        @unique
  title      String
  imageUrl   String
  previewUrl String?
  liveUrl    String?
  published  Boolean       @default(true)
  sortOrder  Int           @default(0)
  categoryId String?
  category   DemoCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([published, sortOrder])
  @@index([categoryId])
}

model Testimonial {
  id             String   @id @default(cuid())
  brand          String
  brandImageUrl  String?
  quote          String
  author         String
  position       String?
  clientImageUrl String?
  rating         Int      @default(5)
  published Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
}

model CompanyLogo {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String?
  website   String?
  published Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
}

model ContactLead {
  id        String     @id @default(cuid())
  name      String?
  company   String?
  phone     String?
  email     String?
  message   String
  status    LeadStatus @default(NEW)
  ipHash    String?
  userAgent String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Media {
  id           String   @id @default(cuid())
  filename     String
  url          String
  originalUrl  String?
  optimizedUrl String?
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  altText      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  resource   String?
  resourceId String?
  username   String?
  details    Json?
  ipHash     String?
  userAgent  String?
  adminId    String?
  admin      Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([resource, createdAt])
}

model DatabaseBackup {
  id               String       @id @default(cuid())
  filename         String       @unique
  type             BackupType   @default(MANUAL)
  status           BackupStatus @default(READY)
  sizeBytes        Int          @default(0)
  note             String?
  createdByAdminId String?
  createdByAdmin   Admin?       @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())

  @@index([type, createdAt])
  @@index([createdAt])
}

model VisitorDaily {
  id          String   @id @default(cuid())
  dateKey     String
  visitorHash String
  pageViews   Int      @default(1)
  firstPath   String?
  lastPath    String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([dateKey, visitorHash])
  @@index([dateKey])
  @@index([createdAt])
}

model SEOSettings {
  id          String   @id @default(cuid())
  route       String   @unique
  title       String
  description String
  keywords    String?
  ogImage     String?
  noIndex     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  type      String   @default("INFO")
  title     String
  message   String
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([read, createdAt])
}

model DownloadCategory {
  id        String         @id @default(cuid())
  name      String
  slug      String         @unique
  items     DownloadItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model DownloadItem {
  id               String            @id @default(cuid())
  slug             String            @unique
  title            String
  description      String?
  additionalInfo   String?
  thumbnailUrl     String?
  fileName         String
  originalFilename String?
  fileMimeType     String            @default("application/octet-stream")
  fileSizeBytes    Int               @default(0)
  livePreviewUrl   String?
  downloadCount    Int               @default(0)
  published        Boolean           @default(true)
  sortOrder        Int               @default(0)
  categoryId       String?
  category         DownloadCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([published, sortOrder])
  @@index([categoryId])
}

model GalleryItem {
  id        String   @id @default(cuid())
  title     String?
  imageUrl  String
  altText   String?
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
}

model BlogCategory {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  posts     BlogPost[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model BlogPost {
  id               String        @id @default(cuid())
  slug             String        @unique
  title            String
  excerpt          String?
  featuredImageUrl String?
  content          Json
  published        Boolean       @default(true)
  publishedAt      DateTime?
  sortOrder        Int           @default(0)
  categoryId       String?
  category         BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([published, publishedAt])
  @@index([sortOrder])
  @@index([categoryId])
}

model PromoBanner {
  id        String   @id @default(cuid())
  location  String
  title     String?
  imageUrl  String
  targetUrl String
  published Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([location, published, sortOrder])
}
